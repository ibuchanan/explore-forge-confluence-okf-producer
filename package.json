{
  "name": "explore-forge-confluence-okf-producer",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "scripts": {
    "build": "tsc",
    "changelog": "git cliff",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run size:check",
    "clean": "rm -rf ./node_modules && rm package-lock.json && rm -rf ./dist",
    "dev": "tsdown --watch",
    "forge:deploy": "source .env && forge deploy --environment \"$FORGE_ENVIRONMENT\"",
    "forge:install": "source .env && forge install --site \"$FORGE_SITE\" --product \"$FORGE_PRODUCT\" --environment \"$FORGE_ENVIRONMENT\" --non-interactive",
    "forge:uninstall": "source .env && forge uninstall --site \"$FORGE_SITE\" --product \"$FORGE_PRODUCT\"",
    "forge:upgrade": "source .env && forge install --upgrade --site \"$FORGE_SITE\" --product \"$FORGE_PRODUCT\" --environment \"$FORGE_ENVIRONMENT\" --non-interactive",
    "forge:variables:set": "source .env && forge variables set --environment \"$FORGE_ENVIRONMENT\"",
    "forge:variables:set-encrypted": "source .env && forge variables set --encrypt --environment \"$FORGE_ENVIRONMENT\"",
    "forge:variables:set:dotenv": "./scripts/forge-vars-from-env.sh",
    "format": "biome format --write",
    "format:check": "biome format",
    "generate": "npm run generate:openapi && npm run generate:rovo",
    "generate:openapi": "openapi-typescript",
    "generate:rovo": "echo 'Not implemented'",
    "lint": "npm run lint:check && forge lint",
    "lint:check": "biome lint",
    "lint:fix": "biome lint --write",
    "lint:prelint": "ast-grep scan --globs '!specs/**' --config ./node_modules/tool-forge-prelint-ast-grep/sgconfig.recommended.yml",
    "prepare": "lefthook install",
    "preview": "echo 'Not implemented'",
    "size:check": "npm run build && size-limit",
    "start": "echo 'Not implemented'",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "todo": "grep -rn 'TODO' --exclude='package.json' . --color=auto || echo 'No TODOs found!'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@forge/api": "^8.0",
    "@forge/bridge": "6.1",
    "@forge/events": "^3.0",
    "@forge/kvs": "^2.0",
    "@forge/object-store": "^2.0",
    "@forge/react": "^12.0",
    "@forge/resolver": "^2.0",
    "@forge-ahead/errors": "github:ibuchanan/forge-ahead-errors",
    "node-html-markdown": "^2.0",
    "node-html-parser": "^9.0",
    "react": "^18.2",
    "yaml": "^2.9",
    "yazl": "^3.3"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.44",
    "@biomejs/biome": "2.5.2",
    "@size-limit/preset-app": "^12.1",
    "@types/node": "*",
    "@types/yauzl": "^3.4",
    "@types/yazl": "^3.3",
    "archunit": "*",
    "git-cliff": "*",
    "lefthook": "^2.1",
    "openapi-typescript": "*",
    "size-limit": "^12.1",
    "tool-forge-prelint-ast-grep": "github:ibuchanan/tool-forge-prelint-ast-grep",
    "typescript": "^5.9",
    "vitest": "*",
    "yauzl": "^3.4.0"
  },
  "size-limit": [
    {
      "name": "compiled Forge app",
      "path": [
        "dist/index.js",
        "dist/resolvers/index.js",
        "dist/frontend/index.js"
      ],
      "limit": "20 kB",
      "running": false
    }
  ],
  "allowScripts": {
    "@ast-grep/cli@0.44.1": true,
    "fsevents@2.3.3": true,
    "iframe-resizer@4.4.5": true,
    "lefthook@2.1.9": true,
    "github:ibuchanan/forge-ahead-errors#ebb8d32cc98d3f53a605989b76419eaa54dd3e5e": true
  }
}
